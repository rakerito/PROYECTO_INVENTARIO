# ============================
# Configuración de Supabase
# ============================

# URL del proyecto en Supabase (Settings > API > Project URL)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clave anónima pública (Settings > API > anon public)
SUPABASE_KEY=your-anon-key-here

# Clave de servicio con permisos completos (opcional, solo backend)
# SUPABASE_SERVICE_KEY=your-service-role-key-here
